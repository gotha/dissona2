# Auth Service Configuration
# Service-specific settings (inherits from root .env)

# Server
SERVER__HOST=0.0.0.0
SERVER__PORT=15001

# Database (Auth database - port 15010)
# DATABASE_URL is for sqlx-cli, DATABASE__URL is for the Rust config
DATABASE_URL=postgres://dissona_auth:dissona_auth@localhost:15010/dissona_auth
DATABASE__URL=postgres://dissona_auth:dissona_auth@localhost:15010/dissona_auth
DATABASE__MAX_CONNECTIONS=5

# JWT (generate with: openssl rand -base64 32)
JWT__SECRET=

# Google OAuth (from Google Cloud Console)
GOOGLE__CLIENT_ID=
GOOGLE__CLIENT_SECRET=
GOOGLE__REDIRECT_URI=http://localhost:15001/auth/callback/google

# Frontend URL (where to redirect after OAuth)
FRONTEND__URL=http://localhost:15003
