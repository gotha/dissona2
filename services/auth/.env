# Auth Service Configuration
# Service-specific settings (inherits from root .env)

# Server
SERVER__HOST=0.0.0.0
SERVER__PORT=8081

# Database (Auth database)
DATABASE__URL=postgres://disona_auth:disona_auth@localhost:5432/disona_auth
DATABASE__MAX_CONNECTIONS=5

# Google OAuth (fill these in)
GOOGLE__CLIENT_ID=
GOOGLE__CLIENT_SECRET=
GOOGLE__REDIRECT_URI=http://localhost/auth/callback/google
