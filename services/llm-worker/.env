# LLM Worker Configuration
# Service-specific settings (inherits from root .env)

# NATS
NATS_URL=nats://localhost:4222

# LiteLLM
LITELLM_URL=http://10.100.0.100:14000
LLM_MODEL=qwen2.5:14b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Observability
METRICS_PORT=9091
OTLP_ENDPOINT=http://localhost:4317
