# TTS Worker Configuration
# Service-specific settings (inherits from root .env)

# NATS
NATS_URL=nats://localhost:4222

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_AUDIO=disona-audio

# TTS Provider
TTS_PROVIDER=kokoro
KOKORO_MODEL_PATH=./models/kokoro-v0_19.onnx

# ElevenLabs (production)
ELEVENLABS_API_KEY=

# Audio settings
AUDIO_FORMAT=aac
AUDIO_BITRATE=128k
AUDIO_SAMPLE_RATE=24000

# Observability
METRICS_PORT=9092
OTLP_ENDPOINT=http://localhost:4317
