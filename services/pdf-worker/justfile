# Disona PDF Worker
# Run `just --list` to see all available commands

set dotenv-load

# Default: show help
default:
    @just --list

# ============ STANDARD COMMANDS ============

# Setup: install dependencies
setup:
    pip install -r requirements.txt
    @touch .venv/.installed

# Build: not applicable for Python (placeholder)
build:
    @echo "Python service - no build step required"

# Run all checks (format, lint, typecheck)
check: fmt-check lint typecheck

# Run all tests with coverage
test:
    pytest src/ --cov=src --cov-report=term-missing --cov-report=lcov:lcov.info

# Clean build artifacts
clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name "*.pyc" -delete 2>/dev/null || true
    rm -rf .pytest_cache .coverage htmlcov lcov.info

# ============ DEVELOPMENT ============

# Run the service locally
run:
    python src/main.py

# ============ CODE QUALITY ============

# Format code
fmt:
    ruff format src/

# Check formatting
fmt-check:
    ruff format --check src/

# Run linter
lint:
    ruff check src/

# Run linter and fix issues
lint-fix:
    ruff check --fix src/

# Type checking
typecheck:
    mypy src/

# ============ DEPENDENCIES ============

# Update dependencies
deps-update:
    pip install --upgrade -r requirements.txt

# Show outdated dependencies
deps-outdated:
    pip list --outdated

# ============ DOCKER ============

# Build Docker image
docker-build:
    docker build -t disona-pdf-worker:latest .

# Run in Docker
docker-run:
    docker run --rm disona-pdf-worker:latest
