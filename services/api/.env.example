# API Service Configuration
# Copy to .env and fill in values

# Server
SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# Database (API database)
DATABASE__URL=postgres://dissona:dissona@localhost:5434/dissona
DATABASE__MAX_CONNECTIONS=10

# NATS
NATS__URL=nats://localhost:4222

# S3 Storage
S3__ENDPOINT=http://localhost:9000
S3__ACCESS_KEY=minioadmin
S3__SECRET_KEY=minioadmin
S3__BUCKET_UPLOADS=dissona-uploads
S3__BUCKET_AUDIO=dissona-audio
