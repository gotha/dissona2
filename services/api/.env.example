# API Service Configuration
# Copy to .env and fill in values

# Server
SERVER__HOST=0.0.0.0
SERVER__PORT=15002

# Database (API database - port 15011)
# DATABASE_URL is for sqlx-cli, DATABASE__URL is for the Rust config
DATABASE_URL=postgres://dissona:dissona@localhost:15011/dissona
DATABASE__URL=postgres://dissona:dissona@localhost:15011/dissona
DATABASE__MAX_CONNECTIONS=10

# NATS (port 15020)
NATS__URL=nats://localhost:15020

# S3 Storage (MinIO port 15030)
S3__ENDPOINT=http://localhost:15030
S3__ACCESS_KEY=minioadmin
S3__SECRET_KEY=minioadmin
S3__BUCKET_UPLOADS=dissona-uploads
S3__BUCKET_AUDIO=dissona-audio
