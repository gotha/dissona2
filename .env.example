# Disona Development Environment Variables
# Copy this file to .env and fill in the values

# ============ AUTH ============
JWT_SECRET=dev-secret-change-in-production-must-be-long-and-random
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============ DATABASES ============
# Auth Service database (users, preferences)
AUTH_DATABASE_URL=postgres://dissona_auth:dissona_auth@localhost:5432/dissona_auth

# API Service database (projects, content)
DATABASE_URL=postgres://dissona:dissona@localhost:5433/dissona

# ============ NATS ============
NATS_URL=nats://localhost:4222

# ============ STORAGE (MinIO for dev) ============
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=dissona-uploads
S3_BUCKET_AUDIO=dissona-audio

# ============ LLM (via LiteLLM proxy) ============
LITELLM_URL=http://10.100.0.100:14000
LLM_MODEL=qwen2.5:14b
LLM_TEMPERATURE=0.3

# ============ TTS ============
TTS_PROVIDER=kokoro
KOKORO_MODEL_PATH=./models/kokoro-v0_19.pth

# ============ FRONTEND ============
VITE_API_URL=http://localhost:80/api
VITE_AUTH_URL=http://localhost:80/auth
