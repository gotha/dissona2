# Disona Development Environment
# This file contains shared secrets and configuration

# ============ SHARED SECRETS ============
JWT_SECRET=dev-secret-change-this-in-production-must-be-at-least-32-chars

# ============ DATABASES ============
AUTH_DATABASE_URL=postgres://disona_auth:disona_auth@localhost:5432/disona_auth
DATABASE_URL=postgres://disona:disona@localhost:5433/disona

# ============ NATS ============
NATS_URL=nats://localhost:4222

# ============ STORAGE (MinIO) ============
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=disona-uploads
S3_BUCKET_AUDIO=disona-audio

# ============ LLM ============
LITELLM_URL=http://10.100.0.100:14000
LLM_MODEL=qwen2.5:14b

# ============ GOOGLE OAUTH (fill in for auth service) ============
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
